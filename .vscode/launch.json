{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: main.py (Lead Generation)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "subProcess": false,
      "envFile": "${workspaceFolder}/.secrets/deepseek.env"
    },
    {
      "name": "Python: Attach 5678 (Lead Generation)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "127.0.0.1",
        "port": 5678
      },
      "justMyCode": true
    }
  ]
}
